{
  "expo": {
    "name": "CivicReel",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "civicreel",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.civicvoice.j8yaqc",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture problems to report to the community",
        "NSPhotoLibraryUsageDescription": "Attach photos of problems from your gallery",
        "NSMicrophoneUsageDescription": "Not used"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.civicvoice.j8yaqc",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Capture problems to report to the community"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos of problems from your gallery"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
